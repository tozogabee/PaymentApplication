meta {
  name: Create - Negative Amount
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/payments
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "amount": -5.0,
    "currency": "EUR",
    "debtorAccount": "DE123456789",
    "creditorAccount": "DE987654321"
  }
}

assert {
  res.status: eq 400
}