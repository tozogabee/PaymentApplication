meta {
  name: Create - Blank Debtor Account
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/payments
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "amount": 100.0,
    "currency": "EUR",
    "debtorAccount": "",
    "creditorAccount": "DE987654321"
  }
}

assert {
  res.status: eq 400
}