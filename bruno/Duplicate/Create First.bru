meta {
  name: Create First
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/payments
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "amount": 33.0,
    "currency": "EUR",
    "debtorAccount": "BRU-DUP-DEBTOR",
    "creditorAccount": "BRU-DUP-CREDITOR"
  }
}

assert {
  res.status: eq 201
  res.body.status: eq CREATED
}

script:post-response {
  if (res.getStatus() === 201) {
    bru.setVar("dupFirstId", res.getBody().id);
  }
}